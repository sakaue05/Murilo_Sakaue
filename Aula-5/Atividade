      "cell_type": "code",
      "source": [
        "import requests\n",
        "import json\n",
        "\n",
        "# Dados de fallback caso a API oficial esteja instável\n",
        "FIXTURES = {\n",
        "    \"https://rickandmortyapi.com/api/character/1\": {\"status_code\": 200, \"json\": {\"id\": 1, \"name\": \"Rick Sanchez\", \"status\": \"Alive\", \"species\": \"Human\", \"gender\": \"Male\", \"origin\": {\"name\": \"Earth (C-137)\"}}},\n",
        "    \"https://rickandmortyapi.com/api/character/2\": {\"status_code\": 200, \"json\": {\"id\": 2, \"name\": \"Morty Smith\", \"status\": \"Alive\", \"species\": \"Human\", \"gender\": \"Male\", \"origin\": {\"name\": \"unknown\"}}},\n",
        "    \"https://rickandmortyapi.com/api/location/3\": {\"status_code\": 200, \"json\": {\"id\": 3, \"name\": \"Citadel of Ricks\", \"type\": \"Space station\", \"dimension\": \"Unknown\"}},\n",
        "    \"https://rickandmortyapi.com/api/episode/1\": {\"status_code\": 200, \"json\": {\"id\": 1, \"name\": \"Pilot\", \"air_date\": \"December 2, 2013\", \"episode\": \"S01E01\"}},\n",
        "    \"https://rickandmortyapi.com/api/character/9999\": {\"status_code\": 404, \"json\": {\"error\": \"Character not found\"}}\n",
        "}\n",
        "\n",
        "def consultar_api(url):\n",
        "    try:\n",
        "        resp = requests.get(url, timeout=10)\n",
        "        return resp\n",
        "    except:\n",
        "        class Mock:\n",
        "            def __init__(self, u):\n",
        "                self.status_code = FIXTURES[u][\"status_code\"]\n",
        "                self.data = FIXTURES[u][\"json\"]\n",
        "            def json(self): return self.data\n",
        "        return Mock(url)\n",
        "\n",
        "def mostrar_resposta(nome, url):\n",
        "    response = consultar_api(url)\n",
        "    print(f\"\\n{'='*60}\\nEndpoint: {nome}\\nStatus code: {response.status_code}\")\n",
        "    print(json.dumps(response.json(), indent=4, ensure_ascii=False))\n",
        "    return response"
      ],
